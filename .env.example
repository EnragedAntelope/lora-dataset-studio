# LoRA Dataset Studio configuration — copy to .env (setup.bat / setup.sh can
# create it for you). NEVER commit .env: it holds your API keys.
# Every studio setting can also be overridden here with the LDS_ prefix.

# --- API keys (all optional — the app tells you which feature needs which) ---
# Cloud image generation + Gemini captioner. https://aistudio.google.com/apikey
# Usage is billed by Google to YOUR key; in-app prices are estimates only.
GEMINI_API_KEY=

# Free-tier cloud captioning (SFW, rate-limited). https://console.groq.com/keys
GROQ_API_KEY=

# Built-in SAM3 subject isolation (gated model): accept the license at
# https://huggingface.co/facebook/sam3 then create a READ token at
# https://huggingface.co/settings/tokens
HF_TOKEN=

# --- Optional overrides (defaults shown) ---
# LDS_COMFY_URL=http://127.0.0.1:8188
# LDS_DEFAULT_ENGINE=gemini            # gemini | comfyui
# LDS_DEFAULT_CAPTIONER=qwen3vl
# LDS_ISOLATION_BACKEND=builtin        # builtin | comfyui
# LDS_RESTORE_BACKEND=auto             # auto | comfyui | basic
# LDS_TARGET_LONG_SIDE=1024
# LDS_OUTPUT_ROOT=./datasets
# LDS_GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# ComfyUI model filenames, if yours are named differently (see docs/comfyui-setup.md)
# LDS_QWEN_EDIT_MODEL=qwen_image_edit_2511_int8_convrot.safetensors
# LDS_ANGLES_LORA=qwen/Qwen-Image-Edit-2511-Multiple-Angles-LoRA.safetensors
# LDS_UPSCALE_MODEL=4xNomosWebPhoto_RealPLKSR.safetensors
# LDS_DEJPG_MODEL=1xDeJPG_OmniSR.pth
# LDS_SAM3_CHECKPOINT=sam3.1_multiplex_fp16.safetensors
